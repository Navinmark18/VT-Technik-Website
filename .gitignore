# Dependenciesnode_modules/        → Alle npm Packages (riesig! ~500MB+)
npm-debug.log        → Debug Logs
yarn-error.log       → Yarn Fehler
node_modules/

# Environment variables
..env                 → Passwörter, API Keys
.env.local           → Locale Secrets
.env.*.local         → Environment-spezifische Secrets

# Build outputs
ddist/                → Vite/Webpack Output
build/               → Build Ordner
*.tsbuildinfo        → TypeScript Cache

# SQLite databases and journals
*.sqlite             → Datenbank Dateien
*.sqlite-*           → Datenbank Backups
*.db                 → Andere Datenbanken
*.db-*

# IDE
.vscode/             → VS Code Settings
.idea/               → PyCharm/IntelliJ Settings
*.swp, *.swo, *~     → Editor Temp-Dateien
*~

# OS
.DS_Store            → macOS Dateien
Thumbs.db            → Windows Dateien

# Misc
.cache/              → Cache Dateien
.turbo/              → Turbo Build Cache
